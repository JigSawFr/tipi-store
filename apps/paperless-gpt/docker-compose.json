{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "image": "ghcr.io/icereed/paperless-gpt:v0.25.1",
      "name": "paperless-gpt",
      "isMain": true,
      "internalPort": 8080,
      "capDrop": [
        "ALL"
      ],
      "environment": [
        {
          "key": "PAPERLESS_BASE_URL",
          "value": "${PAPERLESSGPT_PAPERLESS_BASE_URL}"
        },
        {
          "key": "PAPERLESS_API_TOKEN",
          "value": "${PAPERLESSGPT_PAPERLESS_API_TOKEN}"
        },
        {
          "key": "LLM_PROVIDER",
          "value": "${PAPERLESSGPT_LLM_PROVIDER:-openai}"
        },
        {
          "key": "LLM_MODEL",
          "value": "${PAPERLESSGPT_LLM_MODEL:-gpt-4o}"
        },
        {
          "key": "OPENAI_API_KEY",
          "value": "${PAPERLESSGPT_OPENAI_API_KEY:-}"
        },
        {
          "key": "OLLAMA_HOST",
          "value": "${PAPERLESSGPT_OLLAMA_HOST:-}"
        },
        {
          "key": "GOOGLE_API_KEY",
          "value": "${PAPERLESSGPT_GOOGLE_API_KEY:-}"
        },
        {
          "key": "ANTHROPIC_API_KEY",
          "value": "${PAPERLESSGPT_ANTHROPIC_API_KEY:-}"
        },
        {
          "key": "LLM_LANGUAGE",
          "value": "${PAPERLESSGPT_LLM_LANGUAGE:-English}"
        },
        {
          "key": "VISION_LLM_PROVIDER",
          "value": "${PAPERLESSGPT_VISION_LLM_PROVIDER:-}"
        },
        {
          "key": "VISION_LLM_MODEL",
          "value": "${PAPERLESSGPT_VISION_LLM_MODEL:-}"
        },
        {
          "key": "OCR_PROVIDER",
          "value": "${PAPERLESSGPT_OCR_PROVIDER:-llm}"
        },
        {
          "key": "TOKEN_LIMIT",
          "value": "${PAPERLESSGPT_TOKEN_LIMIT:-0}"
        },
        {
          "key": "PAPERLESS_PUBLIC_URL",
          "value": "${PAPERLESSGPT_PAPERLESS_PUBLIC_URL:-}"
        },
        {
          "key": "MANUAL_TAG",
          "value": "${PAPERLESSGPT_MANUAL_TAG:-paperless-gpt}"
        },
        {
          "key": "AUTO_TAG",
          "value": "${PAPERLESSGPT_AUTO_TAG:-paperless-gpt-auto}"
        },
        {
          "key": "AUTO_OCR_TAG",
          "value": "${PAPERLESSGPT_AUTO_OCR_TAG:-paperless-gpt-ocr-auto}"
        },
        {
          "key": "MISTRAL_API_KEY",
          "value": "${PAPERLESSGPT_MISTRAL_API_KEY:-}"
        },
        {
          "key": "OPENAI_BASE_URL",
          "value": "${PAPERLESSGPT_OPENAI_BASE_URL:-}"
        },
        {
          "key": "OPENAI_API_TYPE",
          "value": "${PAPERLESSGPT_OPENAI_API_TYPE:-}"
        },
        {
          "key": "OLLAMA_CONTEXT_LENGTH",
          "value": "${PAPERLESSGPT_OLLAMA_CONTEXT_LENGTH:-}"
        },
        {
          "key": "OCR_PROCESS_MODE",
          "value": "${PAPERLESSGPT_OCR_PROCESS_MODE:-image}"
        },
        {
          "key": "OCR_LIMIT_PAGES",
          "value": "${PAPERLESSGPT_OCR_LIMIT_PAGES:-5}"
        },
        {
          "key": "PDF_SKIP_EXISTING_OCR",
          "value": "${PAPERLESSGPT_PDF_SKIP_EXISTING_OCR:-false}"
        },
        {
          "key": "AUTO_GENERATE_TITLE",
          "value": "${PAPERLESSGPT_AUTO_GENERATE_TITLE:-true}"
        },
        {
          "key": "AUTO_GENERATE_TAGS",
          "value": "${PAPERLESSGPT_AUTO_GENERATE_TAGS:-true}"
        },
        {
          "key": "AUTO_GENERATE_CORRESPONDENTS",
          "value": "${PAPERLESSGPT_AUTO_GENERATE_CORRESPONDENTS:-true}"
        },
        {
          "key": "AUTO_GENERATE_DOCUMENT_TYPE",
          "value": "${PAPERLESSGPT_AUTO_GENERATE_DOCUMENT_TYPE:-true}"
        },
        {
          "key": "AUTO_GENERATE_CREATED_DATE",
          "value": "${PAPERLESSGPT_AUTO_GENERATE_CREATED_DATE:-true}"
        },
        {
          "key": "LOG_LEVEL",
          "value": "${PAPERLESSGPT_LOG_LEVEL:-info}"
        },
        {
          "key": "CORRESPONDENT_BLACK_LIST",
          "value": "${PAPERLESSGPT_CORRESPONDENT_BLACK_LIST:-}"
        },
        {
          "key": "TZ",
          "value": "${TZ}"
        }
      ],
      "healthCheck": {
        "test": "wget --no-verbose --tries=1 --spider http://localhost:8080/ || exit 1",
        "interval": "30s",
        "timeout": "10s",
        "retries": 3,
        "startPeriod": "30s"
      },
      "securityOpt": [
        "no-new-privileges=true"
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/prompts",
          "containerPath": "/app/prompts"
        }
      ]
    }
  ]
}